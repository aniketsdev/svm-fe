# Browser-side base URL: host only, no `/api/v1` prefix — Orval-generated SDK paths
# already include the full `/api/v1/...` from the backend's OpenAPI document.
VITE_API_BASE_URL=http://localhost:8000

# Used by Orval at SDK regeneration time (`bun run sdk:gen`).
OPENAPI_URL=http://localhost:8000/api/v1/openapi.json

